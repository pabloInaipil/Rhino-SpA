---
// src/components/Hero.astro
// ─────────────────────────────────────────────────────────────
// RHINO® — Hero Split Layout (Opción 2: Moderno/Corporativo)
// Background-image con gradient overlay + stats bar inferior
// ─────────────────────────────────────────────────────────────

import { site } from '@/config/site';

const { hero, stats } = site;

// Icon paths for stats
const statIconPaths: Record<string, string> = {
  helmet:
    'M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z',
  blueprint:
    'M20 6h-8l-2-2H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-6 10H6v-2h8v2zm4-4H6v-2h12v2z',
  'shield-check':
    'M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z',
  headset:
    'M12 1c-4.97 0-9 4.03-9 9v7c0 1.66 1.34 3 3 3h3v-8H5v-2c0-3.87 3.13-7 7-7s7 3.13 7 7v2h-4v8h3c1.66 0 3-1.34 3-3v-7c0-4.97-4.03-9-9-9z',
};
---

<!-- ═════════════════════════════════════════════════════════ -->
<!-- HERO SECTION                                              -->
<!-- ═════════════════════════════════════════════════════════ -->
<section id="inicio" class="hero-section">
  <!-- Background Image -->
  <div
    class="hero-bg"
    style={`background-image: url('${hero.image}');`}
  ></div>

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-32 lg:py-0 w-full">
    <div class="hero-content">
      <!-- Eyebrow -->
      <span class="inline-block mb-4 text-xs font-semibold uppercase tracking-[0.25em] hero-eyebrow opacity-0">
        Su Socio Estratégico en Minería
      </span>

      <!-- Headline -->
      <h1 class="hero-headline hero-animate-1 opacity-0">
        {hero.headline.split('\n').map((line: string, i: number) => (
          <span class={i === 0 ? '' : 'block'}>{line}</span>
        ))}
        <span class="hero-headline-accent">{hero.highlightLine}</span>
      </h1>

      <!-- Divider -->
      <hr class="hero-divider hero-animate-2 opacity-0" />

      <!-- Subheadline -->
      <p class="hero-subheadline hero-animate-3 opacity-0">
        {hero.subheadline}
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-4 mt-8 hero-animate-4 opacity-0">
        <a href={hero.ctaPrimary.href} class="btn-primary">
          {hero.ctaPrimary.label}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href={hero.ctaSecondary.href} class="btn-outline">
          {hero.ctaSecondary.label}
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ═════════════════════════════════════════════════════════ -->
<!-- STATS BAR                                                 -->
<!-- ═════════════════════════════════════════════════════════ -->
<div class="stats-bar">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 lg:grid-cols-4 divide-x divide-white/10">
      {stats.map((stat) => (
        <div class="stat-item">
          <div class="flex items-center justify-center gap-3">
            <svg
              class="w-6 h-6 hidden sm:block"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
              style="color: var(--color-accent-400);"
            >
              <path
                d={statIconPaths[stat.icon] || statIconPaths['helmet']}
              />
            </svg>
            <div>
              <div class="stat-value" data-count={stat.value}>
                {stat.value}
              </div>
              <div class="stat-label">{stat.label}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<!-- ═════════════════════════════════════════════════════════ -->
<!-- HERO ANIMATIONS                                           -->
<!-- ═════════════════════════════════════════════════════════ -->
<style>
  /* Entry animations */
  .hero-eyebrow {
    animation: fadeSlideUp 0.8s ease forwards 0.3s;
  }
  .hero-animate-1 {
    animation: fadeSlideUp 0.8s ease forwards 0.5s;
  }
  .hero-animate-2 {
    animation: fadeSlideRight 0.6s ease forwards 0.9s;
  }
  .hero-animate-3 {
    animation: fadeSlideUp 0.8s ease forwards 1.1s;
  }
  .hero-animate-4 {
    animation: fadeSlideUp 0.8s ease forwards 1.4s;
  }

  @keyframes fadeSlideUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeSlideRight {
    from {
      opacity: 0;
      transform: scaleX(0);
      transform-origin: left;
    }
    to {
      opacity: 1;
      transform: scaleX(1);
      transform-origin: left;
    }
  }

  /* Subtle parallax-like depth on the background */
  @media (prefers-reduced-motion: no-preference) {
    .hero-bg {
      will-change: transform;
      animation: heroZoom 20s ease-in-out infinite alternate;
    }
  }

  @keyframes heroZoom {
    from { transform: scale(1); }
    to { transform: scale(1.06); }
  }
</style>

<script>
  // ── Intersection Observer for scroll reveal ──────────────
  document.addEventListener('DOMContentLoaded', () => {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
    );

    document
      .querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-stagger')
      .forEach((el) => observer.observe(el));
  });
</script>
