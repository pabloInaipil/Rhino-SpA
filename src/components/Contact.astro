---
// src/components/Contact.astro
// ─────────────────────────────────────────────────────────────
// RHINO® — Formulario de Contacto (Web3Forms)
// Redirect a /gracias/ para Google Ads conversion tracking
// ─────────────────────────────────────────────────────────────

import { site } from '@/config/site';

const { phone, phoneDisplay, email, address, services, web3formsKey, businessHours } = site;

declare global {
  interface Window {
    dataLayer: Record<string, any>[];
  }
}
---

<section id="contacto" class="py-20 lg:py-28 relative overflow-hidden">
  <!-- Decorative gold glow -->
  <div class="absolute bottom-0 left-0 w-80 h-80 opacity-5 pointer-events-none"
    style="background: radial-gradient(circle, var(--color-primary-500) 0%, transparent 70%);"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-14 reveal">
      <span
        class="inline-block mb-3 text-xs font-semibold uppercase tracking-[0.2em]"
        style="color: var(--color-accent-500);"
      >
        Conversemos
      </span>
      <h2 class="section-title mb-4">
        Cotice su <span class="text-gold-gradient">Proyecto</span>
      </h2>
      <p class="section-subtitle mx-auto">
        Cuéntenos sobre su proyecto y nuestro equipo le contactará en menos de 24 horas.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">
      <!-- Contact Info (2 cols) -->
      <div class="lg:col-span-2 space-y-8 reveal-left">
        <!-- Phone -->
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 flex items-center justify-center shrink-0"
            style="background: var(--color-primary-50); color: var(--color-primary-600);">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <div>
            <h3 class="font-heading font-bold text-sm uppercase tracking-wide mb-1" style="color: var(--text-heading);">
              Teléfono
            </h3>
            <a
              href={`tel:${phone}`}
              class="text-sm hover:underline"
              style="color: var(--text-body);"
              onclick="window.dataLayer?.push({event:'phone_click',event_category:'contact',event_label:'phone'});"
            >
              {phoneDisplay}
            </a>
          </div>
        </div>

        <!-- Email -->
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 flex items-center justify-center shrink-0"
            style="background: var(--color-primary-50); color: var(--color-primary-600);">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <h3 class="font-heading font-bold text-sm uppercase tracking-wide mb-1" style="color: var(--text-heading);">
              Email
            </h3>
            <a href={`mailto:${email}`} class="text-sm hover:underline" style="color: var(--text-body);">
              {email}
            </a>
          </div>
        </div>

        <!-- Location -->
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 flex items-center justify-center shrink-0"
            style="background: var(--color-primary-50); color: var(--color-primary-600);">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div>
            <h3 class="font-heading font-bold text-sm uppercase tracking-wide mb-1" style="color: var(--text-heading);">
              Ubicación
            </h3>
            <p class="text-sm" style="color: var(--text-body);">
              {address.city}<br />{address.region}
            </p>
          </div>
        </div>

        <!-- Hours -->
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 flex items-center justify-center shrink-0"
            style="background: var(--color-primary-50); color: var(--color-primary-600);">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div>
            <h3 class="font-heading font-bold text-sm uppercase tracking-wide mb-1" style="color: var(--text-heading);">
              Horario
            </h3>
            <p class="text-sm" style="color: var(--text-body);">
              {businessHours}
            </p>
          </div>
        </div>
      </div>

      <!-- Form (3 cols) -->
      <div class="lg:col-span-3 reveal-right">
        <form
          id="contact-form"
          action="https://api.web3forms.com/submit"
          method="POST"
          class="space-y-5 p-8 border"
          style="background: var(--bg-card); border-color: var(--border-default);"
        >
          <!-- Web3Forms hidden fields -->
          <input type="hidden" name="access_key" value={web3formsKey} />
          <input type="hidden" name="subject" value="Nueva cotización — RHINO Web" />
          <input type="hidden" name="from_name" value="RHINO SpA — Web" />
          <input type="hidden" name="redirect" value="https://rhino-spa.cl/gracias/" />
          <!-- Honeypot -->
          <input type="checkbox" name="botcheck" class="hidden" />

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="name" class="form-label">Nombre completo</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="form-input"
                placeholder="Juan Pérez"
              />
            </div>
            <div>
              <label for="email" class="form-label">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="form-input"
                placeholder="juan@empresa.cl"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="phone" class="form-label">Teléfono</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                class="form-input"
                placeholder="+56 9 1234 5678"
              />
            </div>
            <div>
              <label for="service" class="form-label">Servicio de interés</label>
              <select id="service" name="service" class="form-input">
                <option value="">Seleccione un servicio</option>
                {services.map((s) => (
                  <option value={s.title}>{s.title}</option>
                ))}
                <option value="Otro">Otro</option>
              </select>
            </div>
          </div>

          <div>
            <label for="message" class="form-label">Mensaje</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              required
              class="form-input resize-none"
              placeholder="Cuéntenos sobre su proyecto..."
            ></textarea>
          </div>

          <button type="submit" class="btn-primary w-full justify-center">
            Enviar Cotización
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
            </svg>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  // ── Form submission dataLayer push ────────────────────────
  const form = document.getElementById('contact-form') as HTMLFormElement;
  form?.addEventListener('submit', () => {
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event: 'form_submit',
      event_category: 'contact',
      event_label: 'contact_form',
    });
  });
</script>
