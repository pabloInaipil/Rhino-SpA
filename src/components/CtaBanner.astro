---
// src/components/CtaBanner.astro
// ─────────────────────────────────────────────────────────────
// RHINO® — CTA Banner (dark background + gold radial glow)
// ─────────────────────────────────────────────────────────────

import { site } from '@/config/site';
---

<section class="cta-banner py-20 lg:py-24">
  <div class="relative z-10 mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center reveal">
    <h2 class="font-heading font-bold text-3xl lg:text-4xl text-white mb-4 leading-tight">
      ¿Tiene un proyecto minero<br />
      <span class="text-gold-gradient">en desarrollo?</span>
    </h2>
    <p class="text-base text-white/70 max-w-2xl mx-auto mb-8 leading-relaxed">
      Nuestro equipo de ingenieros está listo para evaluar su proyecto y
      entregar una propuesta a la medida de sus necesidades operativas.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href="#contacto" class="btn-primary">
        Solicitar Cotización
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a
        href={`https://wa.me/${site.whatsapp}?text=${encodeURIComponent(site.whatsappMessage)}`}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-outline"
        onclick="window.dataLayer?.push({event:'cta_click',event_category:'cta',event_label:'whatsapp_cta'});"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z" />
          <path d="M12 0C5.373 0 0 5.373 0 12c0 2.136.559 4.143 1.536 5.885L0 24l6.305-1.654A11.95 11.95 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818c-2.02 0-3.935-.538-5.592-1.516l-.401-.238-4.155 1.09 1.109-4.05-.262-.417A9.77 9.77 0 012.182 12c0-5.418 4.4-9.818 9.818-9.818S21.818 6.582 21.818 12 17.418 21.818 12 21.818z" />
        </svg>
        WhatsApp Directo
      </a>
    </div>
  </div>
</section>
