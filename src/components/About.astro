---
// src/components/About.astro
// ─────────────────────────────────────────────────────────────
// RHINO® — Nosotros (split layout: texto + valores)
// ─────────────────────────────────────────────────────────────

import { site } from '@/config/site';

const { about } = site;

const valueIcons: Record<string, string> = {
  shield:
    'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  award:
    'M12 15l-3.09 1.64.59-3.44L7 10.82l3.45-.5L12 7.25l1.55 3.07 3.45.5-2.5 2.38.59 3.44z',
  users:
    'M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 11a4 4 0 100-8 4 4 0 000 8zm14 10v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75',
  leaf:
    'M17 8C8 10 5.9 16.17 3.82 21.34L5.71 22l1-2.3A4.49 4.49 0 008 20c4 0 8.5-3 10.5-8.5S22 2 22 2c-1 0-4.5.5-5 .5z',
};
---

<section id="nosotros" class="py-20 lg:py-28 relative" style="background: var(--bg-surface);">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Left: Text Content -->
      <div class="reveal-left">
        <span
          class="inline-block mb-3 text-xs font-semibold uppercase tracking-[0.2em]"
          style="color: var(--color-accent-500);"
        >
          Quiénes Somos
        </span>
        <h2 class="section-title mb-6">
          {about.title}
        </h2>
        <p class="text-base leading-relaxed mb-8" style="color: var(--text-body);">
          {about.description}
        </p>

        <a href="#contacto" class="btn-outline-dark">
          Hablemos de su Proyecto
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <!-- Right: Values Grid -->
      <div class="grid grid-cols-2 gap-5 reveal-right">
        {about.values.map((value, i) => (
          <div
            class="p-6 border transition-all duration-300 hover:border-[var(--color-primary-500)] group"
            style={`background: var(--bg-card); border-color: var(--border-default);`}
          >
            <div
              class="w-12 h-12 flex items-center justify-center mb-4 transition-colors duration-300"
              style="background: var(--color-primary-50); color: var(--color-primary-600);"
            >
              <svg
                class="w-6 h-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d={valueIcons[value.icon] || valueIcons['shield']}
                />
              </svg>
            </div>
            <h3
              class="font-heading font-bold text-sm uppercase tracking-wide mb-2"
              style="color: var(--text-heading);"
            >
              {value.title}
            </h3>
            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">
              {value.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
