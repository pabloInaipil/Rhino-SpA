---
// src/components/Process.astro
// ─────────────────────────────────────────────────────────────
// RHINO® — Proceso (timeline horizontal, distinto a MGI)
// ─────────────────────────────────────────────────────────────

import { site } from '@/config/site';

const { process } = site;

const processIcons: Record<string, string> = {
  'clipboard-check':
    'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4',
  calendar:
    'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
  'hard-hat':
    'M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z',
  'chart-bar':
    'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
};
---

<section id="proceso" class="py-20 lg:py-28" style="background: var(--bg-surface);">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16 reveal">
      <span
        class="inline-block mb-3 text-xs font-semibold uppercase tracking-[0.2em]"
        style="color: var(--color-accent-500);"
      >
        Metodología
      </span>
      <h2 class="section-title mb-4">
        Nuestro <span class="text-gold-gradient">Proceso</span>
      </h2>
      <p class="section-subtitle mx-auto">
        Un enfoque sistemático para garantizar resultados seguros, eficientes y de calidad.
      </p>
    </div>

    <!-- Timeline Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 reveal-stagger">
      {process.map((step, i) => (
        <div class="process-step text-center relative">
          <!-- Connector line (hidden on first and mobile) -->
          {i > 0 && (
            <div
              class="hidden lg:block absolute top-10 -left-4 w-8 h-0.5"
              style="background: var(--border-default);"
            ></div>
          )}

          <!-- Icon circle -->
          <div class="process-step__icon-wrapper">
            <span class="process-step__number">{i + 1}</span>
            <div class="process-step__icon">
              <svg
                class="w-7 h-7"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d={processIcons[step.icon] || processIcons['clipboard-check']}
                />
              </svg>
            </div>
          </div>

          <h3
            class="text-lg font-heading font-bold mb-2"
            style="color: var(--text-heading);"
          >
            {step.title}
          </h3>
          <p class="text-sm leading-relaxed" style="color: var(--text-muted);">
            {step.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
