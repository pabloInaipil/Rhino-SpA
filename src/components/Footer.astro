---
// src/components/Footer.astro
// ─────────────────────────────────────────────────────────────
// RHINO® — Footer (dark with gold accents)
// ─────────────────────────────────────────────────────────────

import { site } from '@/config/site';

const currentYear = new Date().getFullYear();
const { name, shortName, phone, phoneDisplay, email, address, services, nav, businessHours } = site;
---

<footer>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <img src="/logo.png" alt={`${shortName} logo`} class="h-14 w-auto mb-4" />
        <p class="text-sm leading-relaxed mt-4">
          Servicios integrales de ingeniería, minería y construcción en la Región de Atacama.
        </p>
      </div>

      <!-- Services -->
      <div>
        <h3>Servicios</h3>
        <ul class="space-y-2">
          {services.map((s) => (
            <li>
              <a href="#servicios">{s.title}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Navigation -->
      <div>
        <h3>Navegación</h3>
        <ul class="space-y-2">
          {nav.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3>Contacto</h3>
        <ul class="space-y-3">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" style="color: var(--color-accent-400);">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href={`tel:${phone}`}>{phoneDisplay}</a>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" style="color: var(--color-accent-400);">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href={`mailto:${email}`}>{email}</a>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" style="color: var(--color-accent-400);">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>{address.city}, {address.region}</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" style="color: var(--color-accent-400);">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>{businessHours}</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-white/40">
        &copy; {currentYear} {name}. Todos los derechos reservados.
      </p>
      <p class="text-xs text-white/30">
        Desarrollado por
        <a
          href="https://dataimpulsa.cl"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-[var(--color-accent-400)] transition-colors"
          style="color: var(--color-accent-500);"
        >
          DatAImpulsa
        </a>
      </p>
    </div>
  </div>
</footer>
