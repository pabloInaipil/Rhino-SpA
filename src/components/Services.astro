---
// src/components/Services.astro
// ─────────────────────────────────────────────────────────────
// RHINO® — Servicios (Grid dinámico con cards interactivas)
// Layout: 3+2 asimétrico en desktop, stack en mobile
// ─────────────────────────────────────────────────────────────

import { site } from '@/config/site';

const { services } = site;

// SVG icon paths for mining services
const serviceIcons: Record<string, string> = {
  truck:
    'M8.5 18.5a2.5 2.5 0 100-5 2.5 2.5 0 000 5zm9 0a2.5 2.5 0 100-5 2.5 2.5 0 000 5zM3 4h1l2.68 11h11.64l2.18-8H7.5M5.5 15H19',
  drill:
    'M14 3v4a1 1 0 001 1h3M7 3v4a1 1 0 001 1h3m-4 4l4 8m4-8l-4 8M12 3v8',
  excavator:
    'M4 21h16M6 21V10l4-4 6 4v11M10 6l2-3 2 3M10 17h4v4h-4v-4z',
  building:
    'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0H5m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5h6v5',
  wrench:
    'M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z',
};
---

<section id="servicios" class="py-20 lg:py-28 relative overflow-hidden">
  <!-- Decorative background element -->
  <div class="absolute top-0 right-0 w-96 h-96 opacity-5 pointer-events-none"
    style="background: radial-gradient(circle, var(--color-primary-500) 0%, transparent 70%);"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 reveal">
      <span
        class="inline-block mb-3 text-xs font-semibold uppercase tracking-[0.2em]"
        style="color: var(--color-accent-500);"
      >
        Lo Que Hacemos
      </span>
      <h2 class="section-title mb-4">
        Nuestros <span class="text-gold-gradient">Servicios</span>
      </h2>
      <p class="section-subtitle mx-auto">
        Soluciones integrales para la industria minera con equipos de alto
        rendimiento y personal calificado.
      </p>
    </div>

    <!-- Services Grid: 3 top + 2 centered bottom -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-6 reveal-stagger">
      {services.slice(0, 3).map((service, index) => (
        <div class="service-card group">
          <!-- Icon -->
          <div class="service-card__icon">
            <svg
              class="w-6 h-6"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d={serviceIcons[service.icon] || serviceIcons['wrench']}
              />
            </svg>
          </div>

          <!-- Content -->
          <h3 class="service-card__title">{service.title}</h3>
          <p class="service-card__desc">{service.description}</p>

          <!-- Features list -->
          {service.features && (
            <ul class="mt-4 space-y-2">
              {service.features.map((feat: string) => (
                <li class="flex items-start gap-2 text-sm" style="color: var(--text-body);">
                  <svg
                    class="w-4 h-4 mt-0.5 shrink-0"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                    style="color: var(--color-primary-500);"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M5 13l4 4L19 7"
                    />
                  </svg>
                  {feat}
                </li>
              ))}
            </ul>
          )}

          <!-- Hover arrow -->
          <div class="mt-6 flex items-center gap-2 text-sm font-semibold opacity-0 group-hover:opacity-100 transition-opacity duration-300"
            style="color: var(--color-accent-500);">
            Ver más
            <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom row: 2 cards centered -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-3xl mx-auto reveal-stagger">
      {services.slice(3).map((service) => (
        <div class="service-card group">
          <div class="service-card__icon">
            <svg
              class="w-6 h-6"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d={serviceIcons[service.icon] || serviceIcons['wrench']}
              />
            </svg>
          </div>
          <h3 class="service-card__title">{service.title}</h3>
          <p class="service-card__desc">{service.description}</p>
          {service.features && (
            <ul class="mt-4 space-y-2">
              {service.features.map((feat: string) => (
                <li class="flex items-start gap-2 text-sm" style="color: var(--text-body);">
                  <svg
                    class="w-4 h-4 mt-0.5 shrink-0"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                    style="color: var(--color-primary-500);"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M5 13l4 4L19 7"
                    />
                  </svg>
                  {feat}
                </li>
              ))}
            </ul>
          )}
          <div class="mt-6 flex items-center gap-2 text-sm font-semibold opacity-0 group-hover:opacity-100 transition-opacity duration-300"
            style="color: var(--color-accent-500);">
            Ver más
            <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA below services -->
    <div class="text-center mt-14 reveal">
      <a href="#contacto" class="btn-primary">
        Cotiza tu Proyecto
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
